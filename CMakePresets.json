{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-clang",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "WITH_GENICAM": "ON"
      }
    },
    {
      "name": "base-clang-no-genicam",
      "hidden": true,
      "inherits": "base-clang",
      "cacheVariables": {
        "WITH_GENICAM": "OFF"
      }
    },
    {
      "name": "macos-base-clang",
      "hidden": true,
      "inherits": "base-clang-no-genicam",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/opt/homebrew;/usr/local"
      }
    },
    {
      "name": "x64-debug-clang",
      "displayName": "x64 Debug - Clang",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-release-clang",
      "displayName": "x64 Release - Clang",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x64-debug-clang-no-genicam",
      "displayName": "x64 Debug - Clang (No GenICam)",
      "inherits": "base-clang-no-genicam",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-release-clang-no-genicam",
      "displayName": "x64 Release - Clang (No GenICam)",
      "inherits": "base-clang-no-genicam",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug-clang",
      "displayName": "Linux Debug - Clang",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-clang",
      "displayName": "Linux Release - Clang",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug-clang-no-genicam",
      "displayName": "Linux Debug - Clang (No GenICam)",
      "inherits": "base-clang-no-genicam",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-clang-no-genicam",
      "displayName": "Linux Release - Clang (No GenICam)",
      "inherits": "base-clang-no-genicam",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-debug-clang",
      "displayName": "macOS Debug - Clang",
      "inherits": "macos-base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-release-clang",
      "displayName": "macOS Release - Clang",
      "inherits": "macos-base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ]
}